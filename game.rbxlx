                <Item class="ModuleScript" referent="26">
                  <Properties>
                    <string name="Name">core</string>
                    <string name="Source">local module = require("./../../../../featherfall+quill_core/0.1.0-alpha.2/quill_core/lib")
export type Singleton  = module.Singleton 
export type Lifecycle  = module.Lifecycle 
export type LifecycleHook  = module.LifecycleHook 
export type Phase  = module.Phase 
export type PhaseHook  = module.PhaseHook 
export type Identity  = module.Identity 
export type Mod  = module.Mod 
return module</string>
