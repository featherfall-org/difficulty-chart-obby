          <Item class="ModuleScript" referent="202">
            <Properties>
              <string name="Name">charm-sync</string>
              <string name="Source"><![CDATA[local client = require("@self/client")
local config = require("@self/config")
local patch = require("@self/patch")
local server = require("@self/server")
local types = require("@self/types")
local utils = require("@self/utils")

export type None = types.None
export type SyncPayload = types.SyncPayload

return {
	config = config,
	client = client,
	server = server,
	patch = patch,
	isNone = patch.isNone,
	flatten = utils.flatten,
	signalToAtom = utils.signalToAtom,
}
]]></string>
            </Properties>
            <Item class="ModuleScript" referent="203">
              <Properties>
                <string name="Name">client</string>
                <string name="Source"><![CDATA[local Charm = require("../Charm")
local patch = require("./patch")
local types = require("./types")

type SyncPayload = types.SyncPayload
type ReactiveProxy<T = {}> = types.ReactiveProxy<T>

local trackedSignals: { [string]: (any) -> any } = {}
local trackedReactives: { [string]: ReactiveProxy } = {}

local function shallowMergeReactive(reactive: ReactiveProxy, source: { [any]: any })
	local target = reactive.__target
	for key, value in source do
		target[key] = value
	end
	Charm.trigger(reactive.__track)
end

--[[
	Registers a map of setters to the state with the corresponding keys on the
	server. When the server sends updates, these setters will be called with
	the new values.

	Atoms, signals converted to atoms, and signal setter functions are allowed.
	Note that `server.addSignalsToClient` still requires some way to get the
	state.

	@param signals A map of setter functions to sync with the server.
]]
local function addSignals(signals: { [string]: ((any) -> any) | {} })
	for key, signal in signals do
		if type(signal) == "function" then
			trackedSignals[key] = signal
		else
			trackedReactives[key] = (signal :: any) :: ReactiveProxy
		end
	end
end

--[[
	Unregisters from server state updates for the given keys. The signals
	will retain their current values, but will no longer receive updates
	from the server.
]]
local function removeSignals(...: string)
	for index = 1, select("#", ...) do
		local key = select(index, ...)
		trackedSignals[key] = nil
		trackedReactives[key] = nil
	end
end

--[[
	Unsubscribes from all server state updates.
]]
local function removeAllSignals()
	table.clear(trackedSignals)
	table.clear(trackedReactives)
end

local function applyInitPayload(data: { [string]: any })
	for key, value in data do
		if trackedSignals[key] then
			trackedSignals[key](value)
		elseif trackedReactives[key] then
			shallowMergeReactive(trackedReactives[key], value)
		end
	end
end

local function applyPatchPayload(data: { [string]: any })
	for key, diffs in data do
		local trackedSignal = trackedSignals[key]
		local trackedReactive = trackedReactives[key]

		if trackedSignal then
			trackedSignal(function(value)
				return patch.apply(value, diffs)
			end)
		elseif trackedReactive then
			patch.applyMutable(trackedReactive.__target, diffs)
			Charm.trigger(trackedReactive.__track)
		end
	end
end

--[[
	Merges the server's state patches into the client's state, either
	initializing it with the full state or merging a partial patch.

	@param payloads The state updates received from the server.
]]
local function patch(payloads: { SyncPayload })
	for _, payload in payloads do
		if payload.type == "init" then
			Charm.batch(applyInitPayload, payload.data)
		elseif payload.type == "patch" then
			Charm.batch(applyPatchPayload, payload.data)
		end
	end
end

return {
	addSignals = addSignals,
	removeSignals = removeSignals,
	removeAllSignals = removeAllSignals,
	patch = patch,
}
]]></string>
              </Properties>
            </Item>
            <Item class="ModuleScript" referent="204">
              <Properties>
                <string name="Name">config</string>
                <string name="Source"><![CDATA[return {
	--[[
		The interval at which to send patches to the client, in seconds.
		Defaults to `0` (patches are sent up to once per frame). Set to a
		negative value to disable automatic syncing.
	]]
	interval = 0,
	--[[
		Whether the history of state changes since the client's last update
		should be preserved. This is useful for values that change multiple
		times per frame, where each individual change is important. Defaults
		to `false`.
	]]
	preserveHistory = false,
	--[[
		When `true`, Charm will apply validation and serialize unsafe arrays
		to address remote event argument limitations. Defaults to `true`.
		This option should be disabled if your network library uses a custom
		serialization method (i.e. Zap, ByteNet) to prevent interference.
	]]
	fixArrays = true,
	--[[
		When `true`, synced state containing unsafe sparse arrays or mixed
		tables will throw an error. Only checked in strict mode and if
		`fixArrays` is enabled. Defaults to `true`.
	]]
	validatePatches = true,
}
]]></string>
              </Properties>
            </Item>
            <Item class="ModuleScript" referent="205">
              <Properties>
                <string name="Name">patch</string>
                <string name="Source"><![CDATA[local Charm = require("../Charm")
local config = require("./config")
local types = require("./types")
local validate = require("./validate")

local flags = Charm.flags

export type None = types.None

local None: None = { __none = "__none" }

--[[
	Checks whether a value is `None`. If `true`, the value is scheduled to be
	removed from the state when the patch is applied.

	@param value The value to check.
	@return `true` if the value is `None`, otherwise `false`.
]]
local function isNone(value: any): boolean
	return type(value) == "table" and value.__none == "__none"
end

--[[
	Converts `nil` values to the special `None` symbol. This is useful when
	preparing data for serialization, since `nil` can represent both the absence
	of a value and the removal of a value in patches.
]]
local function nilToNone<T>(value: T?): T | None
	return if value == nil then None else value
end

--[[
	JSON serialization can drop the last values of a sparse array. For example,
	`{ [1] = 1, [3] = 3 }` becomes `[1]` in some cases. Ambiguity in the
	serialization of sparse arrays can be resolved by converting them to
	dictionaries with string keys.

	The `patch` functions will convert these dictionaries back into arrays as
	long as the target array is not sparse. This function ensures that the diff
	function produces a patch that can be correctly applied.
]]
local function stringifySparseArray(object: {}): { [string | number]: any }
	local maxn = table.maxn(object)

	if maxn == 0 or maxn == #object then
		-- The object is either not an array or a dense array
		return object
	end

	local dictionary = {}

	for index, value in object do
		dictionary[tostring(index)] = value
	end

	return dictionary
end

local function diff(oldState: any, newState: any): any
	if oldState == newState then
		return nil
	elseif newState == nil then
		return None
	elseif type(oldState) ~= "table" or type(newState) ~= "table" then
		return newState
	end

	local diffs = table.clone(newState)

	for key, oldValue in oldState do
		diffs[key] = diff(oldValue, newState[key])
	end

	if next(diffs) == nil then
		return nil
	end

	if config.fixArrays then
		-- Convert sparse array patches that could be misserialized
		if oldState[1] ~= nil or newState[1] ~= nil then
			diffs = stringifySparseArray(diffs)
		end
		if flags.strict and config.validatePatches then
			validate(diffs)
		end
	end

	return diffs
end

local function apply(oldState: any, diffs: any): any
	if isNone(diffs) then
		return nil
	elseif type(oldState) ~= "table" or type(diffs) ~= "table" then
		return diffs
	end

	local newState = table.clone(oldState)
	local stateIsArray = oldState[1] ~= nil

	for key, value in diffs do
		-- Diff-checking an array produces a sparse array, which will not be
		-- preserved when converted to JSON. To prevent this, we turn string
		-- keys back into numeric keys.
		if stateIsArray and type(key) == "string" then
			key = tonumber(key) or key
		end
		newState[key] = apply(newState[key], value)
	end

	return newState
end

local function applyMutable(targetState: any, diffs: any): any
	if isNone(diffs) then
		return nil
	elseif type(targetState) ~= "table" or type(diffs) ~= "table" then
		return diffs
	end

	local targetIsArray = targetState[1] ~= nil

	for key, value in diffs do
		if targetIsArray and type(key) == "string" then
			key = tonumber(key) or key
		end
		targetState[key] = applyMutable(targetState[key], value)
	end

	return targetState
end

return {
	isNone = isNone,
	nilToNone = nilToNone,
	diff = diff,
	apply = apply,
	applyMutable = applyMutable,
}
]]></string>
              </Properties>
            </Item>
            <Item class="ModuleScript" referent="206">
              <Properties>
                <string name="Name">server</string>
                <string name="Source"><![CDATA[local Charm = require("../Charm")
local config = require("./config")
local patch = require("./patch")
local types = require("./types")
local utils = require("./utils")

type SyncPayload = types.SyncPayload

type SyncStatus = number

type ClientKeys = { [string]: SyncStatus }

type TrackedState<T = any> = {
	identifier: unknown,
	currentValue: T,
	lastSyncedValue: T,
	isReactive: boolean,
	dispose: () -> (),
}

type StateUpdate = {
	key: string,
	newValue: any,
	oldValue: any,
}

local PENDING_INITIAL_STATE: SyncStatus = 0
local LISTENING_FOR_CHANGES: SyncStatus = 1

local trackedStates: { [string]: TrackedState } = {}
local globalUpdates: { StateUpdate } = {}
local clients: { [any]: ClientKeys } = {}

local connection: RBXScriptConnection?
local syncCallback: ((client: any, payloads: { SyncPayload }) -> ())?

--[[
	Manually converts a reactive proxy to its raw representation to potentially
	support custom implementations of reactive proxies.
]]
local function toRaw<T>(value: T): T
	if type(value) == "table" and type(value.__target) == "table" and type(value.__track) == "function" then
		value.__track()
		return toRaw(value.__target)
	end
	return value
end

local function trackSignal<T>(key: string, getter: () -> T, identifier: unknown)
	if trackedStates[key] then
		-- Warn against name collisions with conflicting signals or proxies
		if trackedStates[key].identifier ~= identifier then
			warn("[Charm] Attempted to sync different states with the same key:", key)
		end
		return
	end

	local trackedState: TrackedState<T>
	local initialValue = getter()
	local rawInitialValue = toRaw(initialValue)
	local snapshot = if initialValue ~= rawInitialValue then utils.deepCopy(rawInitialValue) else initialValue

	local dispose = Charm.effect(function()
		local newValue = getter()
		local rawValue = toRaw(newValue)
		local isReactive = newValue ~= rawValue

		if not trackedState then
			return
		end

		-- When preserving history, we need to keep track of previous values
		-- so we can create granular patches for each change.
		if config.preserveHistory then
			local prevSnapshot = snapshot
			snapshot = if isReactive then utils.deepCopy(rawValue) else newValue
			table.insert(globalUpdates, {
				key = key,
				newValue = snapshot,
				oldValue = prevSnapshot,
			})
		end

		trackedState.currentValue = rawValue
		trackedState.isReactive = isReactive
	end)

	trackedState = {
		identifier = identifier,
		currentValue = rawInitialValue,
		lastSyncedValue = snapshot,
		isReactive = initialValue ~= rawInitialValue,
		dispose = dispose,
	}

	trackedStates[key] = trackedState
end

local function stopTracking(key: string)
	local trackedState = trackedStates[key]
	if trackedState then
		trackedState.dispose()
		trackedStates[key] = nil
	end
end

local function purgeUntracked()
	local active: { [string]: boolean } = {}

	for _, clientKeys in clients do
		for key in clientKeys do
			active[key] = true
		end
	end

	for key in trackedStates do
		if not active[key] then
			stopTracking(key)
		end
	end
end

local function diffGlobalUpdateBuffer(): { any }
	local patchCount = #globalUpdates
	local patches = table.create(patchCount)

	for _, update in globalUpdates do
		table.insert(patches, patch.diff(update.oldValue, update.newValue))
	end

	return patches
end

local function selectFromGlobalPatchList(client: any, globalPatches: { any }): { SyncPayload }?
	local clientKeys = clients[client]

	if not clientKeys then
		return nil
	end

	local payloads: { SyncPayload } = {}

	-- Iterate over all global updates and see if the client is interested in
	-- any of them. If so, we create a patch payload for the update.
	for index, update in globalUpdates do
		local patchData = globalPatches[index]

		if not patchData then
			continue
		end

		local key = update.key
		local status = clientKeys[key]

		if status == LISTENING_FOR_CHANGES then
			table.insert(payloads, {
				type = "patch",
				data = { [key] = patchData },
			})
		elseif status == PENDING_INITIAL_STATE then
			table.insert(payloads, {
				type = "init",
				data = { [key] = update.newValue },
			})
			clientKeys[key] = LISTENING_FOR_CHANGES
		end
	end

	-- If a pending signal was never updated, we still need to send its initial
	-- state. This can happen if a signal was registered after its last change.
	local initData = {}

	for key, status in clientKeys do
		local trackedState = trackedStates[key]

		if status == PENDING_INITIAL_STATE and trackedState then
			initData[key] = trackedState.currentValue
			clientKeys[key] = LISTENING_FOR_CHANGES
		end
	end

	if next(initData) ~= nil then
		table.insert(payloads, 1, { type = "init" :: "init", data = initData })
	end

	return payloads
end

local function diffGlobalState(): { [string]: any }?
	local currentGlobalState: { [string]: any } = {}
	local previousGlobalState: { [string]: any } = {}

	for key, trackedState in trackedStates do
		local currentValue = if trackedState.isReactive
			then utils.deepCopy(trackedState.currentValue)
			else trackedState.currentValue

		currentGlobalState[key] = currentValue
		previousGlobalState[key] = trackedState.lastSyncedValue
		trackedState.lastSyncedValue = currentValue
	end

	return patch.diff(previousGlobalState, currentGlobalState)
end

local function selectFromGlobalPatch(client: any, globalPatch: { [string]: any }?): { SyncPayload }?
	local clientKeys = clients[client]

	if not clientKeys then
		return nil
	end

	local payloads: { SyncPayload } = {}
	local initData: { [string]: any } = {}
	local patchData: { [string]: any } = {}

	-- Create patches for initialized signals that changed, and add signals
	-- that are still pending initial state to the init payload.
	for key, status in clientKeys do
		local trackedState = trackedStates[key]

		if status == LISTENING_FOR_CHANGES and globalPatch then
			patchData[key] = globalPatch[key]
		elseif status == PENDING_INITIAL_STATE then
			initData[key] = trackedState.currentValue
			clientKeys[key] = LISTENING_FOR_CHANGES
		end
	end

	if next(initData) ~= nil then
		table.insert(payloads, { type = "init", data = initData })
	end

	if next(patchData) ~= nil then
		table.insert(payloads, { type = "patch", data = patchData })
	end

	return payloads
end

local function startInterval(callback: () -> ())
	if not game then
		return
	end

	if connection then
		connection:Disconnect()
	end

	local timestamp = os.clock()

	connection = game:GetService("RunService").Heartbeat:Connect(function()
		if config.interval >= 0 and os.clock() >= timestamp + config.interval then
			timestamp = os.clock()
			debug.profilebegin("CharmSync")
			callback()
			debug.profileend()
		end
	end)
end

--[[
	Subscribes a client to the given signals. When an update occurs, the client
	will receive a partial state patch to merge into their local state. May be
	called multiple times to subscribe to additional keys.

	Atoms, signals converted to atoms, and signal getter functions are allowed.
	Note that `client.addSignals` still requires some way to set the state.

	@param client The client receiving state updates.
	@param signals A map of getter functions to sync with the client.
]]
local function addSignalsToClient(client: any, signals: { [string]: {} | () -> any })
	if not clients[client] then
		clients[client] = {}
	end

	local clientKeys = clients[client]

	for key, signal in signals do
		if type(signal) == "function" then
			trackSignal(key, signal, signal)
		else
			trackSignal(key, function()
				return signal
			end, signal)
		end

		if not clientKeys[key] then
			-- Mark the signal as pending initial state so we send its full
			-- value the next time we sync.
			clientKeys[key] = PENDING_INITIAL_STATE
		end
	end
end

--[[
	Unsubscribes a client from receiving all state updates. To only unsubscribe
	from specific keys, use `unsubscribeClientFrom` instead.

	@param client The client receiving state updates.
]]
local function removeClient(client: any)
	clients[client] = nil
	purgeUntracked()
end

--[[
	Unsubscribes a client from receiving updates for the given keys.

	@param client The client receiving state updates.
	@param keys The keys of the state to unsubscribe from.
]]
local function removeSignalsFromClient(client: any, ...: string)
	local clientKeys = clients[client]

	if not clientKeys then
		return
	end

	for index = 1, select("#", ...) do
		local key = select(index, ...)
		clientKeys[key] = nil
	end

	if next(clientKeys) == nil then
		removeClient(client)
	else
		purgeUntracked()
	end
end

--[[
	Immediately sends pending updates to all clients. Normally, updates are
	sent at the interval specified in `config.interval`, but this function
	can be used to force an immediate sync.
]]
local function flush()
	if not syncCallback then
		return
	end

	local granular = config.preserveHistory
	local globalPatch: { [any]: any }? = if granular then diffGlobalUpdateBuffer() else diffGlobalState()

	for client in clients do
		local payloads = if granular
			then selectFromGlobalPatchList(client, globalPatch :: { any })
			else selectFromGlobalPatch(client, globalPatch)

		if payloads and payloads[1] then
			if task then
				task.spawn(syncCallback, client, payloads)
			else
				syncCallback(client, payloads)
			end
		end
	end

	table.clear(globalUpdates)
end

--[[
	Uses the callback to send state updates to clients that are subscribed
	to state changes. Starts automatically sending updates at the interval
	specified in `config.interval`.

	@param onSync Called when sending patches to a client.
]]
local function connect(onSync: (client: any, payloads: { SyncPayload }) -> ())
	syncCallback = onSync
	startInterval(flush)
end

--[[
	Stops syncing state updates to clients at the automatic interval.
	Flushing can still be performed manually via `flush`.
]]
local function disconnect()
	if connection then
		connection:Disconnect()
		connection = nil
	end
end

--[[
	Unsubscribes all clients, stops tracking all state, and disconnects
	from the automatic sync interval.
]]
local function reset()
	table.clear(trackedStates)
	table.clear(clients)
	table.clear(globalUpdates)
	disconnect()
end

return {
	addSignalsToClient = addSignalsToClient,
	removeClient = removeClient,
	removeSignalsFromClient = removeSignalsFromClient,
	connect = connect,
	disconnect = disconnect,
	flush = flush,
	reset = reset,
}
]]></string>
              </Properties>
            </Item>
            <Item class="ModuleScript" referent="207">
              <Properties>
                <string name="Name">types</string>
                <string name="Source"><![CDATA[--[[
	A payload that can be sent from the server to the client to synchronize
	the states of the client's atoms with the server.
]]
export type SyncPayload =
	| {
		type: "init",
		data: { [string]: any },
	}
	| {
		type: "patch",
		data: { [string]: any },
	}

--[[
	A special type that represents a removed value in a patch. This is used to
	differentiate between a value that was set to `nil` and an unchanged value.
]]
export type None = { __none: "__none" }

export type ReactiveProxy<T = any> = typeof(setmetatable(
	{} :: {
		__track: () -> (),
		__target: T,
		__signals: { [unknown]: () -> unknown },
	},
	{} :: { __index: T }
))

return {}
]]></string>
              </Properties>
            </Item>
            <Item class="ModuleScript" referent="208">
              <Properties>
                <string name="Name">utils</string>
                <string name="Source"><![CDATA[local Charm = require("../Charm")

type Atom<T> = Charm.Atom<T>

type NestedTable = {
	[any]: NestedTable | any,
}

--[[
	Flattens a nested table into a single table with slash-separated keys.
	Useful for recursively collecting atoms returned by modules.

	@param input A nested table.
	@return A flattened table with slash-separated keys.
]]
local function flatten<Flattened>(input: {}): Flattened
	local result = {}

	local function visit(node: {}, path: string)
		for key, value in node do
			local location = if path == "" then tostring(key) else path .. "/" .. tostring(key)

			if type(value) == "table" then
				visit(value :: {}, location)
			else
				result[location] = value
			end
		end
	end

	visit(input, "")

	return result :: any
end

--[[
	Converts a signal getter and setter into an atom. This is useful for
	syncing client signals with the server, as the sync system requires both
	the getter and setter to update state.

	@param getter A function that returns the current value of the signal.
	@param setter A function that sets the value of the signal.
	@return An atom that can either get or set the signal's value.
]]
local function signalToAtom<T>(getter: () -> T, setter: (value: ((T) -> T) | T) -> T): Atom<T>
	return function(...)
		return if select("#", ...) == 0 then getter() else setter((...))
	end
end

--[[
	Returns a deep copy of the given table. Skips tables with metatables to
	prevent copying reactive proxies.
]]
local function deepCopy<T>(object: T): T
	local copy: any = table.clone(object :: any)
	for key, value in copy do
		if type(value) == "table" and getmetatable(value) == nil then
			copy[key] = deepCopy(value)
		end
	end
	return copy
end

return {
	flatten = flatten,
	signalToAtom = signalToAtom,
	deepCopy = deepCopy,
}
]]></string>
              </Properties>
            </Item>
            <Item class="ModuleScript" referent="209">
              <Properties>
                <string name="Name">validate</string>
                <string name="Source"><![CDATA[local function isTableUnsafe(object: {})
	local key = next(object)

	if key == nil then
		return false
	end

	local keyType = type(key)
	local maxKey = 0

	-- Keys must all be the same type
	for key in object do
		if type(key) ~= keyType then
			return true
		elseif type(key) == "number" and key > maxKey then
			maxKey = key
		end
	end

	-- Array keys must be sequential
	if keyType == "number" and maxKey > #object then
		return true
	end

	return false
end

--[[
	Emits a warning if the value is a table that cannot be synced via
	RemoteEvents or RemoteFunctions. This only aims to catch common mistakes
	with remote argument limitations, such as sparse arrays or mixed tables.

	@param value The table value.
	@param key The key of the value.
]]
local function validate(value: {})
	if isTableUnsafe(value) then
		warn(
			`Cannot sync tables unsupported by remote events! See the table below for more info.\n\n`
				.. "This can be for the following reasons:\n"
				.. "1. The table is a sparse array with non-sequential indices\n"
				.. "2. The table is a mixed table (not all keys have the same type)\n\n"
				.. "Read more: https://create.roblox.com/docs/scripting/events/remote#argument-limitations\n",
			value
		)
	end
end

return validate
]]></string>
              </Properties>
            </Item>
          </Item>
        </Item>
        <Item class="Folder" referent="210">
          <Properties>
            <string name="Name">littensy_charm@0.11.0-rc.5</string>
          </Properties>
          <Item class="ModuleScript" referent="211">
            <Properties>
              <string name="Name">charm</string>
              <string name="Source"><![CDATA[--[[
	Reactive system adapted from alien-signals at
	https://github.com/stackblitz/alien-signals/blob/master/src/system.ts
]]

local system = require("@self/system")

export type Link = system.Link
export type ReactiveFlags = system.ReactiveFlags
export type ReactiveNode = system.ReactiveNode

local link = system.link
local unlink = system.unlink
local propagate = system.propagate
local checkDirty = system.checkDirty
local shallowPropagate = system.shallowPropagate
local createReactiveSystem = system.createReactiveSystem

export type Getter<T> = () -> T
export type Setter<T> = (update: Update<T>) -> T
export type Atom<T = any> = (...Update<T>) -> T
export type Update<T> = ((current: T) -> T) | T
export type Equals<T> = (current: T, incoming: T) -> boolean
export type Cleanup = () -> ()

type EffectScopeNode = ReactiveNode & {
	cleanups: { Cleanup },
}

type EffectNode = ReactiveNode & {
	fn: () -> ...Cleanup?,
	cleanups: { Cleanup },
}

type ComputedNode<T = any> = ReactiveNode & {
	value: T?,
	getter: (previousValue: T?) -> T,
}

type SignalNode<T = any> = ReactiveNode & {
	currentValue: T,
	pendingValue: T,
}

-- Bitmask flags for tracking the state of reactive nodes. Flags are combined
-- and checked using bitwise operations for efficiency.
local NONE = 0b000000 -- Default state
local MUTABLE = 0b000001 -- Can be changed (signal or computed)
local WATCHING = 0b000010 -- Watching for changes (effects)
local RECURSED_CHECK = 0b000100 -- Being checked for circular dependencies
local DIRTY = 0b010000 -- Value has changed and needs updating
local PENDING = 0b100000 -- Might be dirty, pending verification

-- Global version counter for dependency link deduplication. Incremented at the
-- start of each effect/computed run to ensure links created in the same cycle
-- are deduplicated.
local cycle = 0
-- Effects runs are queued to prevent redundant executions when multiple
-- signals update in the same batch.
local queued: { EffectNode? } = {}
local queuedLength = 0
local notifyIndex = 0
-- Batch operations group multiple updates together, deferring effect runs
-- until the batch completes. Effects only run when the outermost batch ends.
local batchDepth = 0
-- Tracks the currently active effect or computed signal during execution.
-- Dependencies accessed during this time will link to the active subscriber.
local activeSub: ReactiveNode?

local function isO2(): boolean
	return debug.info(1, "n") ~= "isO2"
end

local flags = {
	--[[
		Enforces synchronous, non-yielding behavior in signals and effects.
		Also enables state validation in Charm Sync to catch sync errors early.
		Enabled if the optimization level is below 2, which is true in studio.
	]]
	strict = not isO2(),
	--[[
		Enforces immutability of tables by deep-freezing table values. Enabled
		if the optimization level is below 2, which is true in studio.
	]]
	frozen = not isO2(),
	--[[
		Whether parent effects should track inner effects and clean them up
		when the parent effect re-runs. This is usually desirable, but can be
		disabled to revert to the old behavior. Defaults to `true`.
	]]
	trackInnerEffects = true,
}

--[[
	Wraps a function to prevent yielding when in strict mode. If the function
	attempts to yield, an error is thrown.

	@param fn The function to wrap.
	@return A wrapped function that cannot yield in strict mode.
]]
local function noYield<Args..., Results...>(fn: (Args...) -> Results...): (Args...) -> Results...
	if not flags.strict then
		return fn
	end

	local function resultHandler(thread: thread, ok: boolean, ...)
		if not ok then
			error(debug.traceback(thread, tostring((...))))
		elseif coroutine.status(thread) ~= "dead" then
			error(debug.traceback(thread, "Yielding is not allowed in strict mode"))
		end
		return ...
	end

	return function(...)
		local thread = coroutine.create(fn)
		return resultHandler(thread, coroutine.resume(thread, ...))
	end
end

--[[
	Recursively freezes a table and all nested tables to enforce immutability.
	Tables with metatables are skipped, as they are assumed to be mutable.

	@param value Table to freeze
]]
local function deepFreeze(value: any)
	if type(value) == "table" and not table.isfrozen(value) and getmetatable(value) == nil then
		table.freeze(value)
		for _, entry in value do
			deepFreeze(entry)
		end
	end
end

--[[
	Returns the currently active subscriber (effect or computed node).

	@return Current active subscriber or `nil`
]]
local function getActiveSub(): ReactiveNode?
	return activeSub
end

--[[
	Sets the currently active subscriber (effect or computed node) and returns
	the previous subscriber.

	@param sub New subscriber to set as active
	@return Previous active subscriber
]]
local function setActiveSub(sub: ReactiveNode?)
	local prevSub = activeSub
	activeSub = sub
	return prevSub
end

--[[
	Removes dependencies from the subscriber's dependency list. When called
	after tracking is complete, this ensures that only currently tracked
	dependencies remain linked.

	@param sub Effect or computed node
]]
local function purgeDeps(sub: ReactiveNode)
	local depsTail = sub.depsTail
	local dep = if depsTail then depsTail.nextDep else sub.deps
	while dep do
		dep = unlink(dep, sub)
	end
end

--[[
	Runs all cleanup functions registered with the effect node. Any errors
	thrown during cleanup are caught and logged as warnings.

	@param cleanups List of cleanup functions
]]
local function runCleanups(cleanups: { Cleanup })
	for key, cleanup in cleanups do
		local prevSub = setActiveSub(nil)
		cleanups[key] = nil
		xpcall(cleanup, function(err)
			warn("Error occurred during effect cleanup:", debug.traceback(tostring(err), 2))
		end)
		activeSub = prevSub
	end
end

--[[
	Checks if the effect node needs to run based on its flags and dependencies.
	Effects run if they are marked dirty or pending with dirty dependencies.

	@param effect Effect node to run
]]
local function run(effect: EffectNode)
	local flags = effect.flags

	if bit32.btest(flags, DIRTY) or (bit32.btest(flags, PENDING) and checkDirty(effect.deps :: Link, effect)) then
		runCleanups(effect.cleanups)

		cycle += 1
		effect.depsTail = nil
		effect.flags = WATCHING

		local prevSub = setActiveSub(effect)
		local success, result = pcall(effect.fn)
		activeSub = prevSub

		purgeDeps(effect)

		if not success then
			error(result)
		elseif result then
			table.insert(effect.cleanups, noYield(result))
		end
	else
		effect.flags = WATCHING
	end
end

--[[
	Processes the queued effect runs. Effects are run in the order they were
	queued, ensuring that all updates are processed.
]]
local function flush()
	while notifyIndex < queuedLength do
		local effect = queued[notifyIndex] :: EffectNode
		queued[notifyIndex] = nil
		notifyIndex += 1
		run(effect)
	end

	notifyIndex = 0
	queuedLength = 0
end

--[[
	Starts a batch operation, incrementing the batch depth counter. Effects
	will not run until the outermost batch ends.
]]
local function startBatch()
	batchDepth += 1
end

--[[
	Ends a batch operation, decrementing the batch depth counter. If this is
	the outermost batch, queued effects are flushed and run.
]]
local function endBatch()
	batchDepth -= 1
	if batchDepth == 0 then
		flush()
	end
end

--[[
	Updates a computed signal by re-evaluating its getter function. Returns
	whether the computed value changed.

	@param computed Computed node to update
	@return Boolean indicating whether the computed value changed
]]
local function updateComputed(computed: ComputedNode): boolean
	cycle += 1
	computed.depsTail = nil
	computed.flags = bit32.bor(MUTABLE, RECURSED_CHECK)

	local prevSub = setActiveSub(computed)
	local oldValue = computed.value
	local success, newValue = pcall(computed.getter, oldValue)
	activeSub = prevSub

	computed.flags = bit32.band(computed.flags, bit32.bnot(RECURSED_CHECK))
	purgeDeps(computed)

	if success then
		computed.value = newValue
		return oldValue ~= newValue
	else
		error(newValue)
	end
end

--[[
	Updates a signal by applying its pending value. Returns whether the
	signal's value changed.

	@param signal Signal node to update
	@return Boolean indicating whether the signal's value changed
]]
local function updateSignal(signal: SignalNode): boolean
	signal.flags = MUTABLE
	local pendingValue = signal.pendingValue
	if signal.currentValue ~= pendingValue then
		signal.currentValue = pendingValue
		return true
	else
		return false
	end
end

--[[
	Clears the pending flag from a subscriber. Used inside of if conditions to
	inline the operation.

	@param sub Effect or computed node
	@param flags Subscriber's current flags
]]
local function clearPending(sub: ReactiveNode, flags: ReactiveFlags)
	sub.flags = bit32.band(flags, bit32.bnot(PENDING))
end

--[[
	Performs a thorough cleanup of the given effect or effect scope:

	1. Removes all dependency links
	2. Unlinks from parent effects/scopes
	3. Clears state flags to mark the effect as inactive
	4. Runs all registered cleanup functions

	@param this Effect node
]]
local function stopEffect(this: EffectScopeNode)
	this.depsTail = nil
	this.flags = NONE

	purgeDeps(this)

	local sub = this.subs
	if sub then
		unlink(sub, this)
	end

	runCleanups(this.cleanups)
end

--[[
	Updates a signal or computed value and returns whether the value changed.

	@param node Signal or computed node
	@return Boolean indicating whether the value changed
]]
local function update(node: ReactiveNode): boolean
	if node.depsTail then
		return updateComputed(node :: ComputedNode)
	else
		return updateSignal(node :: SignalNode)
	end
end

--[[
	Queues an effect for execution, ensuring inner effects are notified in the
	correct order.

	@param effect Effect node to notify
]]
local function notify(effect: ReactiveNode)
	local insertIndex = queuedLength
	local firstInsertedIndex = insertIndex

	-- Collect inner effects in a chain
	repeat
		queued[insertIndex] = effect :: EffectNode
		insertIndex += 1

		effect.flags = bit32.band(effect.flags, bit32.bnot(WATCHING))
		effect = (effect.subs and effect.subs.sub) :: EffectNode

		if not effect or bit32.band(effect.flags, WATCHING) == 0 then
			break
		end
	until false

	queuedLength = insertIndex

	-- Reverse the collected effects to ensure outer effects run first
	while true do
		insertIndex -= 1
		if firstInsertedIndex >= insertIndex then
			break
		end
		queued[firstInsertedIndex], queued[insertIndex] = queued[insertIndex], queued[firstInsertedIndex]
		firstInsertedIndex += 1
	end
end

--[[
	Called when a node is not being watched by any subscribers. Cleans up the
	node's dependencies and performs the necessary cleanup operations:

	- Computed signals: Unlink dependencies and mark as dirty for potential future updates
	- Effects/scopes: Perform full cleanup to free resources

	@param node Reactive node (computed or effect/scope)
]]
local function unwatched(node: ReactiveNode)
	if bit32.band(node.flags, MUTABLE) == 0 then
		stopEffect(node :: EffectScopeNode)
	elseif node.depsTail then
		node.depsTail = nil
		node.flags = bit32.bor(MUTABLE, DIRTY)
		purgeDeps(node)
	end
end

--[[
	Creates a reactive signal that stores a value and notifies subscribers when
	the value changes. The signal provides both a getter and a setter.

	@param initialValue Initial value for the signal
	@param equals Optional comparator function to check for value changes
	@return Getter function to read the signal value
	@return Setter function to update the signal value
	@see https://github.com/littensy/charm?tab=readme-ov-file#signalinitialValue-equals
]]
local function signal<T>(initialValue: T, equals: Equals<T>?): (Getter<T>, Setter<T>)
	local this: SignalNode = {
		currentValue = initialValue,
		pendingValue = initialValue,
		flags = MUTABLE,
	}

	if flags.frozen then
		deepFreeze(initialValue)
	end

	local function writeSignal(update: Update<T>): T
		local value: T

		-- Determine the new value based on whether the update is a function or
		-- a direct value
		if type(update) == "function" then
			local prevSub = setActiveSub(nil)
			local success, result = pcall(noYield(update), this.pendingValue)
			activeSub = prevSub

			if success then
				value = result
			else
				error(result)
			end
		else
			value = update
		end

		-- Check if the new value is different from the pending value
		if if equals then not equals(this.pendingValue, value) else this.pendingValue ~= value then
			if flags.frozen then
				deepFreeze(value)
			end

			this.pendingValue = value
			this.flags = bit32.bor(MUTABLE, DIRTY)

			local subs = this.subs
			if subs then
				propagate(subs)
				if batchDepth == 0 then
					flush()
				end
			end

			return value
		end

		return this.currentValue
	end

	local function readSignal(): T
		-- Check if the signal needs to be updated (for signals within effects)
		if bit32.btest(this.flags, DIRTY) then
			if updateSignal(this) then
				local subs = this.subs
				if subs then
					shallowPropagate(subs)
				end
			end
		end

		-- Register this signal as a dependency of the active subscriber
		local sub = activeSub
		while sub do
			if bit32.btest(sub.flags, bit32.bor(MUTABLE, WATCHING)) then
				link(this, sub, cycle)
				break
			end
			local subs = sub.subs
			sub = if subs then subs.sub else nil
		end

		return this.currentValue
	end

	return readSignal, writeSignal
end

--[[
	Creates a signal and returns a function that can act as both the getter and
	setter. Calling the atom with one argument sets its value, while calling it
	with no arguments returns its current value.

	@param initialValue Initial value for the atom
	@param equals Optional comparator function to check for value changes
	@see https://github.com/littensy/charm?tab=readme-ov-file#atominitialValue-equals
]]
local function atom<T>(initialValue: T, equals: Equals<T>?): Atom<T>
	local get, set = signal(initialValue, equals)
	local function atomOper(...)
		return if select("#", ...) == 0 then get() else set((...))
	end
	return atomOper
end

--[[
	Creates a new read-only signal that is computed based on the values of
	other signals. The computed signal's value is automatically updated when a
	change is detected in any of its dependencies.

	@param getter Function that calculates the next value
	@return A function that returns the cached value
	@see https://github.com/littensy/charm?tab=readme-ov-file#computedgetter
]]
local function computed<T>(getter: (previousValue: T?) -> T): Getter<T>
	local this: ComputedNode = {
		flags = NONE,
		getter = noYield(getter),
	}

	local function readComputed(): T
		local flags = this.flags

		if
			bit32.btest(flags, DIRTY)
			or (bit32.btest(flags, PENDING) and (checkDirty(this.deps :: Link, this) or clearPending(this, flags)))
		then
			if updateComputed(this) then
				-- Notify subscribers if the value changed
				local subs = this.subs
				if subs then
					shallowPropagate(subs)
				end
			end
		elseif flags == NONE then
			-- First access should initialize the computed value
			this.flags = bit32.bor(MUTABLE, RECURSED_CHECK)

			local prevSub = setActiveSub(this)
			local success, result = pcall(this.getter)
			activeSub = prevSub

			this.flags = bit32.band(this.flags, bit32.bnot(RECURSED_CHECK))

			if success then
				this.value = result
			else
				error(result)
			end
		end

		if activeSub then
			link(this, activeSub, cycle)
		end

		return this.value :: T
	end

	return readComputed
end

--[[
	Creates an effect that runs a callback in response to signal state changes.
	An effect tracks which signals are accessed during its execution, and runs
	the callback when those signals change.

	The effect callback may return a cleanup function, which gets called once,
	either before the effect re-runs or when it is disposed.

	If the effect is called within another effect, it will be disposed when the
	parent effect re-runs.

	@param fn Function to execute reactively
	@return A cleanup function that stops the effect
	@see https://github.com/littensy/charm?tab=readme-ov-file#effectcallback
]]
local function effect(fn: () -> ...Cleanup?): Cleanup
	local this: EffectNode = {
		fn = noYield(fn),
		flags = WATCHING,
		cleanups = {},
	}

	if activeSub and (flags.trackInnerEffects or activeSub.flags == NONE) then
		link(this, activeSub, 0)
	end

	local prevSub = setActiveSub(this)
	local success, result = pcall(this.fn)
	activeSub = prevSub

	if not success then
		error(result)
	elseif result then
		table.insert(this.cleanups, noYield(result))
	end

	return function()
		stopEffect(this)
	end
end

--[[
	Creates an effect scope that can capture reactive effects and computed
	signals created within it so that they can be disposed together.

	@param fn Function that creates effects within the scope
	@param detached If true, the scope will not be tracked by the parent effect/scope
	@return A cleanup function that stops all effects in the scope
	@see https://github.com/littensy/charm?tab=readme-ov-file#effectscopecallback-detached
]]
local function effectScope(fn: () -> ...Cleanup?, detached: boolean?): Cleanup
	local this: EffectScopeNode = {
		flags = NONE,
		cleanups = {},
	}

	if activeSub and not detached then
		link(this, activeSub, 0)
	end

	local prevSub = setActiveSub(this)
	local success, result = pcall(noYield(fn))
	activeSub = prevSub

	if not success then
		error(result)
	elseif result then
		table.insert(this.cleanups, noYield(result))
	end

	return function()
		stopEffect(this)
	end
end

--[[
	Allows you to manually trigger updates for downstream dependencies when
	you've directly mutated a signal's value without using the signal setter.

	@param fn A signal or function that accesses signals
	@see https://github.com/littensy/charm?tab=readme-ov-file#triggercallback
]]
local function trigger(fn: () -> ())
	local sub: ReactiveNode = {
		flags = WATCHING,
	}

	local prevSub = setActiveSub(sub)
	local success, result: any = pcall(noYield(fn))
	activeSub = prevSub

	if not success then
		error(result)
	end

	local link = sub.deps
	while link do
		local dep = link.dep
		link = unlink(link, sub)
		local subs = dep.subs
		if subs then
			sub.flags = NONE
			propagate(subs)
			shallowPropagate(subs)
		end
	end

	if batchDepth == 0 then
		flush()
	end
end

--[[
	Binds the cleanup function to the current active effect or effect scope. If
	there is no active effect, a warning is logged, unless `failSilently` is
	set to `true`.

	@param fn Function to run during cleanup
	@param failSilently If true, silences the warning when called outside an effect/scope
	@see https://github.com/littensy/charm?tab=readme-ov-file#oncleanupcallback-failsilently
]]
local function onCleanup(fn: Cleanup, failSilently: boolean?)
	if activeSub and (activeSub :: EffectNode).cleanups then
		table.insert((activeSub :: EffectNode).cleanups, noYield(fn))
	elseif not failSilently then
		warn(debug.traceback("onCleanup() can only be called inside an effect or a scope.", 2))
	end
end

--[[
	Runs the function without subscribing to signal updates and prevents the
	current effect or scope from tracking inner effects created within the
	function.

	To avoid tracking signals while still allowing inner effects to be tracked
	by parent effects/scopes, use `effectScope()` instead.

	@param fn A signal or function that accesses signals
	@param ...args Arguments to pass to the function
	@return Values returned by the function
	@see https://github.com/littensy/charm?tab=readme-ov-file#untrackedcallback
]]
local function untracked<Args..., Results...>(fn: (Args...) -> Results..., ...: Args...): Results...
	if activeSub then
		local prevSub = setActiveSub(nil)
		local results: { any } = { pcall(noYield(fn), ...) }
		activeSub = prevSub
		if not results[1] then
			error(results[2])
		end
		return unpack(results, 2)
	else
		return fn(...)
	end
end

--[[
	Combines multiple updates into a single "commit" that runs effects and
	computed signals after the provided callback finishes running.

	@param fn Function that updates signals
	@param ...args Arguments to pass to the function
	@return Values returned by the function
	@see https://github.com/littensy/charm?tab=readme-ov-file#batchcallback
]]
local function batch<Args..., Results...>(fn: (Args...) -> Results..., ...: Args...): Results...
	startBatch()
	local results: { any } = { pcall(noYield(fn), ...) }
	endBatch()
	if not results[1] then
		error(results[2])
	end
	return unpack(results, 2)
end

--[[
	Wraps a function in a computed signal if it is not already a reactive
	signal. Useful for memoizing a getter function without creating unnecessary
	nested signals.

	@param fn A signal or function that accesses signals
	@return `fn` wrapped in a computed signal if needed
]]
local function toComputed<T>(fn: Getter<T>): Getter<T>
	local name = debug.info(fn, "n")
	return if name == "readSignal" or name == "readComputed" or name == "atomOper" then fn else computed(fn)
end

--[[
	Creates an effect that runs the callback one immediately, and then again
	when the value returned by the getter changes. The callback receives the
	new value and the previous value as arguments.

	Effects created within the callback are cleaned up when the listener runs
	or the listener is disposed.

	@param getter A signal or function that accesses signals
	@param fn Function to run when the value changes
	@return A cleanup function that stops the effect
	@see https://github.com/littensy/charm?tab=readme-ov-file#listengetter-callback
]]
local function listen<T>(getter: Getter<T>, fn: (state: T, lastState: T?) -> ()): Cleanup
	local tracked = toComputed(getter)
	local current: T

	return effect(function()
		local previous = current
		current = tracked()
		untracked(fn, current, previous)
	end)
end

--[[
	Creates an effect that only runs the callback when the value returned by
	the getter changes. The callback receives the new value and the previous
	value as arguments.

	Effects created within the callback are cleaned up when the listener runs
	or the listener is disposed.

	@param getter A signal or function that accesses signals
	@param fn Function to run when the value changes
	@return A cleanup function that stops the effect
	@see https://github.com/littensy/charm?tab=readme-ov-file#subscribegetter-callback
]]
local function subscribe<T>(getter: Getter<T>, fn: (state: T, lastState: T) -> ()): Cleanup
	local tracked = toComputed(getter)
	local current: T
	local firstRun = true

	return effect(function()
		local previous = current
		current = tracked()
		if firstRun then
			firstRun = false
		else
			untracked(fn, current, previous)
		end
	end)
end

--[[
	Calls the callback function for each unique key in the table returned by the
	getter. The callback is called once for each key, and again when a new key
	is added.

	The callback may return a cleanup function, which will be called when the
	key is removed or the `observe()` effect is disposed. Effects created
	during the callback will also be bound to the lifetime of the key.

	@param getter A signal or function that returns a table
	@param fn Function that is called for each key added to the table
	@return A cleanup function that disposes scopes for all keys
	@see https://github.com/littensy/charm?tab=readme-ov-file#observegetter-callback
]]
local function observe<K, V>(getter: Getter<{ [K]: V }>, fn: (item: V, key: K) -> ...Cleanup?): Cleanup
	local innerScopes: { [K]: Cleanup } = {}
	local disposed = false

	local function updateScopes(data: { [K]: V })
		for key, dispose in innerScopes do
			if data[key] == nil then
				innerScopes[key] = nil
				dispose()
				if disposed then
					return
				end
			end
		end

		for key, value in data do
			if innerScopes[key] == nil then
				local disposeScope = effectScope(function()
					return fn(value, key)
				end, true)
				if disposed then
					return disposeScope()
				end
				innerScopes[key] = disposeScope
			end
		end
	end

	return effectScope(function()
		effect(function()
			-- Batch so that side effects run after all scopes are created.
			-- This ensures that a scope creating or removing items doesn't
			-- interfere with the current update cycle.
			batch(updateScopes, getter())
		end)

		return function()
			disposed = true
			for key, dispose in innerScopes do
				innerScopes[key] = nil
				dispose()
			end
		end
	end)
end

--[[
	Creates a new read-only signal that is computed by mapping over the entries
	of an existing atom. If the key is omitted from the mapper's return value,
	the original key is preserved.

	@param getter A signal or function that returns a table
	@param mapper Function that maps each entry from the source to a new entry in the mapped table
	@see https://github.com/littensy/charm?tab=readme-ov-file#mappedgetter-mapper
]]
local function mapped<KI, VI, KO, VO>(getter: Getter<{ [KI]: VI }>, mapper: (VI, KI) -> (VO, KO)): Getter<{ [KO]: VO }>
	local currentInput: { [KI]: VI } = {}
	local keyCache: { [KI]: KO } = {}

	local function map(value: VI, key: KI): (VO, KO)
		local prevSub = setActiveSub(nil)
		local success, valueOut, keyOut = pcall(mapper, value, key)
		activeSub = prevSub
		if not success then
			error(`mapped() transform function failed: {valueOut}`)
		end
		return valueOut, if keyOut == nil then key else keyOut :: any
	end

	return computed(function(previousOutput)
		local currentOutput: { [KO]: VO } = previousOutput or {}
		local previousInput = currentInput
		currentInput = getter()

		for keyIn in previousInput do
			if currentInput[keyIn] ~= nil then
				continue
			end

			local prevKeyOut = keyCache[keyIn]

			if prevKeyOut then
				if currentOutput == previousOutput then
					currentOutput = table.clone(currentOutput)
				end
				currentOutput[prevKeyOut] = nil
				keyCache[keyIn] = nil
			end
		end

		for keyIn, valueIn in currentInput do
			if valueIn == previousInput[keyIn] then
				continue
			end

			local valueOut, keyOut = map(valueIn, keyIn)

			if currentOutput[keyOut] ~= valueOut then
				if currentOutput == previousOutput then
					currentOutput = table.clone(currentOutput)
				end
				currentOutput[keyOut] = valueOut
				keyCache[keyIn] = keyOut
			end
		end

		return currentOutput
	end)
end

createReactiveSystem(update, notify, unwatched)

return {
	ReactiveFlags = system.ReactiveFlags,
	flags = flags,
	atom = atom,
	signal = signal,
	computed = computed,
	effect = effect,
	effectScope = effectScope,
	trigger = trigger,
	untracked = untracked,
	batch = batch,
	subscribe = subscribe,
	listen = listen,
	observe = observe,
	mapped = mapped :: (<KI, VI, KO, VO>(
		getter: Getter<{ [KI]: VI }>,
		mapper: (VI, KI) -> (VO, KO)
	) -> Getter<{ [KO]: VO }>) & (<K, VI, VO>(getter: Getter<{ [K]: VI }>, mapper: (VI, K) -> VO) -> Getter<{ [K]: VO }>),
	onCleanup = onCleanup,
	getActiveSub = getActiveSub,
	setActiveSub = setActiveSub,
	startBatch = startBatch,
	endBatch = endBatch,
}
]]></string>
            </Properties>
            <Item class="ModuleScript" referent="212">
              <Properties>
                <string name="Name">system</string>
                <string name="Source"><![CDATA[--[[
	Reactive system adapted from alien-signals at
	https://github.com/stackblitz/alien-signals/blob/master/src/system.ts
]]

export type ReactiveNode = {
	deps: Link?,
	depsTail: Link?,
	subs: Link?,
	subsTail: Link?,
	flags: ReactiveFlags,
}

export type Link = {
	version: number,
	dep: ReactiveNode,
	sub: ReactiveNode,
	prevSub: Link?,
	nextSub: Link?,
	prevDep: Link?,
	nextDep: Link?,
}

type Stack<T> = {
	value: T,
	prev: Stack<T>?,
}

export type ReactiveFlags = number

local NONE = 0b000000
local MUTABLE = 0b000001
local WATCHING = 0b000010
local RECURSED_CHECK = 0b000100
local RECURSED = 0b001000
local DIRTY = 0b010000
local PENDING = 0b100000

local ReactiveFlags = table.freeze({
	None = NONE,
	Mutable = MUTABLE,
	Watching = WATCHING,
	RecursedCheck = RECURSED_CHECK,
	Recursed = RECURSED,
	Dirty = DIRTY,
	Pending = PENDING,
})

local update: (sub: ReactiveNode) -> boolean
local notify: (sub: ReactiveNode) -> ()
local unwatched: (sub: ReactiveNode) -> ()

local function isValidLink(checkLink: Link, sub: ReactiveNode): boolean
	local link = sub.depsTail
	while link do
		if link == checkLink then
			return true
		end
		link = link.prevDep
	end
	return false
end

local function link(dep: ReactiveNode, sub: ReactiveNode, version: number)
	local prevDep = sub.depsTail
	if prevDep and prevDep.dep == dep then
		return
	end
	local nextDep = if prevDep then prevDep.nextDep else sub.deps
	if nextDep and nextDep.dep == dep then
		nextDep.version = version
		sub.depsTail = nextDep
		return
	end
	local prevSub = dep.subsTail
	if prevSub and prevSub.version == version and prevSub.sub == sub then
		return
	end
	local newLink: Link = {
		version = version,
		dep = dep,
		sub = sub,
		prevDep = prevDep,
		nextDep = nextDep,
		prevSub = prevSub,
	}
	sub.depsTail = newLink
	dep.subsTail = newLink
	if nextDep then
		nextDep.prevDep = newLink
	end
	if prevDep then
		prevDep.nextDep = newLink
	else
		sub.deps = newLink
	end
	if prevSub then
		prevSub.nextSub = newLink
	else
		dep.subs = newLink
	end
end

local function unlink(link: Link, sub: ReactiveNode?): Link?
	local sub = sub or link.sub
	local dep = link.dep
	local prevDep = link.prevDep
	local nextDep = link.nextDep
	local nextSub = link.nextSub
	local prevSub = link.prevSub
	if nextDep then
		nextDep.prevDep = prevDep
	else
		sub.depsTail = prevDep
	end
	if prevDep then
		prevDep.nextDep = nextDep
	else
		sub.deps = nextDep
	end
	if nextSub then
		nextSub.prevSub = prevSub
	else
		dep.subsTail = prevSub
	end
	if prevSub then
		prevSub.nextSub = nextSub
	else
		dep.subs = nextSub
		if not nextSub then
			unwatched(dep)
		end
	end
	return nextDep
end

local function propagate(link: Link)
	repeat
		local sub = link.sub
		local flags = sub.flags

		if bit32.band(flags, bit32.bor(RECURSED_CHECK, RECURSED, DIRTY, PENDING)) == 0 then
			sub.flags = bit32.bor(flags, PENDING)
		elseif bit32.band(flags, bit32.bor(RECURSED_CHECK, RECURSED)) == 0 then
			flags = NONE
		elseif bit32.band(flags, RECURSED_CHECK) == 0 then
			sub.flags = bit32.bor(bit32.band(flags, bit32.bnot(RECURSED)), PENDING)
		elseif bit32.band(flags, bit32.bor(DIRTY, PENDING)) == 0 and isValidLink(link, sub) then
			sub.flags = bit32.bor(flags, bit32.bor(RECURSED, PENDING))
			flags = bit32.band(flags, MUTABLE)
		else
			-- selene: allow(if_same_then_else)
			flags = NONE
		end

		if bit32.band(flags, bit32.bor(WATCHING, RECURSED_CHECK)) == WATCHING then
			notify(sub)
		end

		if bit32.btest(flags, MUTABLE) then
			local subSubs = sub.subs
			if subSubs then
				propagate(subSubs)
			end
		end

		link = link.nextSub :: Link
	until not link
end

local function shallowPropagate(link: Link)
	repeat
		local sub = link.sub
		local flags = sub.flags
		if bit32.band(flags, bit32.bor(PENDING, DIRTY)) == PENDING then
			sub.flags = bit32.bor(flags, DIRTY)
			if bit32.band(flags, bit32.bor(WATCHING, RECURSED_CHECK)) == WATCHING then
				notify(sub)
			end
		end
		link = link.nextSub :: Link
	until not link
end

local function checkDirty(link: Link, sub: ReactiveNode): boolean
	repeat
		local dep = link.dep
		local depFlags = dep.flags

		if bit32.btest(sub.flags, DIRTY) then
			return true
		elseif bit32.band(depFlags, bit32.bor(MUTABLE, DIRTY)) == bit32.bor(MUTABLE, DIRTY) then
			if update(dep) then
				local subs = dep.subs :: Link
				if subs.nextSub then
					shallowPropagate(subs)
				end
				return true
			end
		elseif bit32.band(depFlags, bit32.bor(MUTABLE, PENDING)) == bit32.bor(MUTABLE, PENDING) then
			if checkDirty(dep.deps :: Link, dep) then
				if update(dep) then
					local subs = dep.subs :: Link
					if subs.nextSub then
						shallowPropagate(subs)
					end
					return true
				end
			else
				dep.flags = bit32.band(depFlags, bit32.bnot(PENDING))
			end
		end

		link = link.nextDep :: Link
	until not link

	return false
end

local function createReactiveSystem(
	updateFn: (sub: ReactiveNode) -> boolean,
	notifyFn: (sub: ReactiveNode) -> (),
	unwatchedFn: (sub: ReactiveNode) -> ()
)
	update = updateFn
	notify = notifyFn
	unwatched = unwatchedFn
end

return {
	ReactiveFlags = ReactiveFlags,
	link = link,
	unlink = unlink,
	propagate = propagate,
	checkDirty = checkDirty,
	shallowPropagate = shallowPropagate,
	createReactiveSystem = createReactiveSystem,
}
]]></string>
              </Properties>
            </Item>
          </Item>
        </Item>
