                <string name="Source">return {
	package = {
		authors = {"Stephen Leitnick"},
		description = "Represent optional values in Lua",
		license = "MIT",
		name = "sleitnick/option",
		realm = "shared",
		registry = "https://github.com/UpliftGames/wally-index",
