          <Item class="ModuleScript" referent="215">
            <Properties>
              <string name="Name">Vide</string>
              <string name="Source">local module = require(script.Parent.Parent:FindFirstChild("centau_vide@0.4.0"):FindFirstChild("vide"))
export type source&lt;T> = module.source&lt;T>
