        <string name="Name">server</string>
        <token name="RunContext">0</token>
        <string name="Source"><![CDATA[local components = require(game:GetService('ReplicatedStorage'):FindFirstChild('pkg'):FindFirstChild('quill_rblx_components'))
local core = require(game:GetService('ReplicatedStorage'):FindFirstChild('pkg'):FindFirstChild('quill_core'))
local dependencies = require(game:GetService('ReplicatedStorage'):FindFirstChild('pkg'):FindFirstChild('quill_dependencies'))
local lifecycles = require(game:GetService('ReplicatedStorage'):FindFirstChild('pkg'):FindFirstChild('quill_rblx_lifecycles'))
local logger = require(game:GetService('ReplicatedStorage'):FindFirstChild('pkg'):FindFirstChild('quill_logger'))

local server_logger = logger.new("sever_logger", logger.console_subscriber)

local ct = script:WaitForChild("ct"):GetChildren() :: { ModuleScript }
local services =
    script:WaitForChild("services"):GetChildren() :: { ModuleScript }

core.new()
    :with_mod(dependencies.mod())
    :with_mod(lifecycles.mod())
    :with_mod(components.mod())
    :with_modules(ct)
    :with_modules(services)
    :write()

server_logger:info("Server successfully bootstrapped.")
]]></string>
